# 小瀾 AI 秘書 — 環境變數範本（複製成 .env 後填入真值；本檔不含任何機密）
# 盤點來源：api/*.js、server.js、scripts/ 內所有 process.env.* 用法。

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=   # LINE 官方帳號的 channel access token（push/reply 用）
LINE_CHANNEL_SECRET=         # LINE channel secret（webhook 簽章驗證用）

# --- Supabase（資料庫）---
SUPABASE_URL=                # Supabase 專案 URL
SUPABASE_ANON_KEY=           # Supabase anon public key

# --- Anthropic（Claude）---
ANTHROPIC_API_KEY=           # Claude API 金鑰（語意理解／對話用）

# --- Google OAuth／API（行事曆／試算表／雲端硬碟／Vision）---
GOOGLE_CLIENT_ID=            # Google OAuth 用戶端 ID
GOOGLE_CLIENT_SECRET=        # Google OAuth 用戶端密鑰
GOOGLE_REDIRECT_URI=         # Google OAuth 重導 URI（給 sheets/drive client 用）
GOOGLE_REFRESH_TOKEN=        # Google refresh token（離線存取；可由 /api/oauth 重發）
GOOGLE_VISION_API_KEY=       # Google Vision API 金鑰（運單／收據 OCR）

# --- 對外網址（搬 NAS 用）---
# 設了就用它組對外連結（如 /api/oauth 的 OAuth 重導）；沒設時程式 fallback 回原 Vercel 網址。
# NAS 上線時填本機對外網址（如 https://你的網域），並記得去 Google Console 加對應重導 URI。
PUBLIC_BASE_URL=
# 服務監聽埠（server.js；預設 3000，Docker 內維持 3000、對外映射 3005）。
PORT=

# --- 員工問題回報（staff.html / api/staff-report.js）---
STAFF_REPORT_SPREADSHEET_ID=   # 員工回報試算表 ID
STAFF_REPORT_IMAGE_FOLDER_ID=  # 回報照片上傳的 Google Drive 資料夾 ID
STAFF_REPORT_SHEET_NAME=員工問題回報      # 問題回報分頁名（預設：員工問題回報）
STAFF_REPORT_ORDER_SHEET_NAME=所有訂單    # 訂單查詢分頁名（預設：所有訂單）
STAFF_REPORT_GROUP_ID=         # 員工回報所屬 LINE 群組 ID
STAFF_LIFF_ID=                 # 員工回報 LIFF 表單的 LIFF ID
STAFF_LIFF_CHANNEL_ID=         # 員工回報 LIFF 的 channel ID（選填，有設才驗 idToken）

# --- 丸十支出 LIFF 表單（maruten-expense.html / api/maruten-expense-form.js）---
MARUTEN_EXPENSE_LIFF_ID=        # 丸十支出表單 LIFF ID（選填，未設用程式內後備值）
MARUTEN_EXPENSE_LIFF_CHANNEL_ID=# 丸十支出 LIFF 的 channel ID（選填，有設才驗 idToken）
MARUTEN_RECEIPT_FOLDER_ID=      # 收據照片上傳的 Drive 資料夾 ID（未設沿用 STAFF_REPORT_IMAGE_FOLDER_ID）
MARUTEN_EXPENSE_SHEET_ID=       # 丸十支出寫入的試算表 ID（選填）

# --- 其他 ---
# 目前 owner 的 LINE userId 存在 DB（xlan_kv.owner_line_id）、由對話自動綁定，程式不直接讀此環境變數。
# 此項保留作為部署備忘／未來改吃環境變數時用；一般情況留空即可。
OWNER_LINE_USER_ID=
